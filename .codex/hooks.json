{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.codex/hooks/agent-command-gate.sh\"",
            "timeout": 15,
            "statusMessage": "Enforcing issue-implementer/pr-reviewer push/merge boundary"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.codex/hooks/codex-rate-limit-stop-hook.sh\"",
            "timeout": 15,
            "statusMessage": "Checking Codex rate-limit status"
          }
        ]
      }
    ]
  }
}
